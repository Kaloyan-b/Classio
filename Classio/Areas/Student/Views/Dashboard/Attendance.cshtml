@using Classio.Areas.Teacher.Models
@model Classio.Areas.Student.Models.StudentAttendanceViewModel

@{
    ViewData["Title"] = "Attendance History";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0" style="color: #E76F51;">
                <i class="bi bi-calendar-x me-2"></i>Attendance History
            </h2>
            <p class="text-muted mb-0">Your recorded absences and lates</p>
        </div>
        <div class="d-flex align-items-center gap-3">
            <div class="badge fs-5 fw-bold" style="background-color: #E76F51;">
                Total: @Model.TotalWeightedAbsences
            </div>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    <div class="glass-card-light p-0 border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr style="background: rgba(244, 162, 97, 0.1); border-bottom: 1px solid rgba(244, 162, 97, 0.2);">
                        <th class="ps-4 small text-uppercase fw-bold" style="color: #264653;">Date</th>
                        <th class="small text-uppercase fw-bold" style="color: #264653;">Subject</th>
                        <th class="small text-uppercase fw-bold" style="color: #264653;">Status</th>
                        <th class="small text-uppercase fw-bold" style="color: #264653;">Reported By</th>
                        <th class="text-end pe-4 small text-uppercase fw-bold" style="color: #264653;">Weight</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Absences.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <i class="bi bi-check-circle display-4 mb-2" style="color: #2A9D8F;"></i>
                                <p class="text-muted mb-0 fs-5">No absences or lates recorded.</p>
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model.Absences)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold" style="color: #264653;">@item.Date.ToShortDateString()</td>
                            <td>@item.SubjectName</td>
                            <td>
                                @if (item.State == AttendanceState.Late)
                                {
                                    <span class="badge" style="background-color: #F4A261;">
                                        <i class="bi bi-clock-history"></i> Late
                                    </span>
                                }
                                else
                                {
                                    <span class="badge" style="background-color: #E76F51;">
                                        <i class="bi bi-x-circle"></i> Absent
                                    </span>
                                }
                            </td>
                            <td class="text-muted">@item.TeacherName</td>
                            <td class="text-end pe-4 fw-bold" style="color: #264653;">@item.Weight.ToString("0.0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
