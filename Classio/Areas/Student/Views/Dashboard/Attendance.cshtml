@using Classio.Areas.Teacher.Models
@model Classio.Areas.Student.Models.StudentAttendanceViewModel


@{
    ViewData["Title"] = "Attendance History";
}

<div class="container py-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div class="d-flex align-items-center">
            <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i> Back</a>
            <h2 class="mb-0">Attendance History</h2>
        </div>
        <div class="badge bg-danger fs-5">
            Total: @Model.TotalWeightedAbsences
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Date</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th>Reported By</th>
                        <th class="text-end pe-4">Weight</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Absences.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No absences or lates recorded.</td>
                        </tr>
                    }
                    @foreach (var item in Model.Absences)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@item.Date.ToLongDateString()</td>
                            <td>@item.SubjectName</td>
                            <td>
                                @if (item.State == AttendanceState.Late)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> Late</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Absent</span>
                                }
                            </td>
                            <td class="text-muted">@item.TeacherName</td>
                            <td class="text-end pe-4 fw-bold">@item.Weight.ToString("0.0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>