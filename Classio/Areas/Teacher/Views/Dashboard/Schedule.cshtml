@using Classio.Models
@using Classio.Areas.Teacher.Models

@{
    ViewData["Title"] = "My Schedule";
    var periods = (List<ClassPeriod>)ViewBag.Periods;
    var days = (DayOfWeek[])ViewBag.Days;
    var slots = (Dictionary<DayOfWeek, Dictionary<int, TeacherScheduleSlotInfo?>>)ViewBag.Slots;

    var dayNames = new Dictionary<DayOfWeek, string>
    {
        [DayOfWeek.Monday]    = "Monday",
        [DayOfWeek.Tuesday]   = "Tuesday",
        [DayOfWeek.Wednesday] = "Wednesday",
        [DayOfWeek.Thursday]  = "Thursday",
        [DayOfWeek.Friday]    = "Friday"
    };
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0 fw-bold" style="color:#E76F51;">
                <i class="bi bi-calendar3 me-2"></i>My Schedule
            </h2>
            <p class="text-muted mb-0">Your weekly teaching timetable</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-action="ExportSchedule" class="btn fw-bold px-4 py-2 shadow-sm" style="background:#2A9D8F; color:white; border-radius:8px;">
                <i class="bi bi-google me-1"></i> Export to Google Calendar
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                <i class="bi bi-arrow-left me-1"></i> Back
            </a>
        </div>
    </div>

    @if (!periods.Any())
    {
        <div class="card shadow-sm border-0 p-5 text-center">
            <i class="bi bi-calendar-x display-1 mb-3 opacity-50" style="color:#F4A261;"></i>
            <h3 class="fw-bold">No schedule found</h3>
            <p class="text-muted">Your timetable hasn't been configured yet.</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0 p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-bordered mb-0 schedule-table">
                    <thead>
                        <tr>
                            <th class="text-center align-middle py-3" style="background:#264653; color:#fff; width:120px;">
                                <i class="bi bi-clock me-1"></i>Period
                            </th>
                            @foreach (var day in days)
                            {
                                <th class="text-center align-middle py-3" style="background:#264653; color:#fff;">
                                    @dayNames[day]
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var period in periods)
                        {
                            <tr>
                                <td class="text-center align-middle py-3" style="background:rgba(38,70,83,0.05);">
                                    <div class="fw-semibold" style="color:#264653;">@period.Name</div>
                                    <small class="text-muted">
                                        @period.StartTime.ToString(@"hh\:mm") – @period.EndTime.ToString(@"hh\:mm")
                                    </small>
                                </td>
                                @foreach (var day in days)
                                {
                                    var slot = slots[day][period.Id];
                                    <td class="align-middle p-2 text-center">
                                        @if (slot != null)
                                        {
                                            <div class="slot-card mx-auto p-2 rounded-3">
                                                <div class="fw-semibold" style="color:#264653;">@slot.SubjectName</div>
                                                <small class="text-muted">
                                                    <i class="bi bi-people me-1"></i>@slot.ClassName
                                                </small>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted opacity-25">—</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

<style>
    .schedule-table th, .schedule-table td {
        border-color: rgba(38, 70, 83, 0.12) !important;
    }

    .slot-card {
        background: rgba(42, 157, 143, 0.12);
        border: 1px solid rgba(42, 157, 143, 0.3);
        max-width: 160px;
        transition: background 0.2s;
    }

        .slot-card:hover {
            background: rgba(42, 157, 143, 0.22);
        }
</style>
