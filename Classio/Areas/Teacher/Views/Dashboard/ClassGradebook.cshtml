@using Classio.Models
@using Classio.Areas.Teacher.Models
@model ClassGradebookViewModel

@{
    ViewData["Title"] = "Class Session - " + Model.ClassName;
}

<div class="card mb-4 p-3 bg-light border-0">
    <form method="get" asp-action="ClassGradebook" class="row g-3 align-items-end">
        <input type="hidden" name="id" value="@Model.ClassId" />

        <div class="col-md-6">
            <label class="form-label fw-bold">Select Session / Class:</label>
            <select name="sessionKey" class="form-select" onchange="changeSession(this)">
                @foreach (var session in Model.AvailableSessions)
                {
                    var val = $"{session.Date:yyyy-MM-dd}_{session.PeriodId}";
                    var isSelected = session.Date == Model.SelectedDate && session.PeriodId == Model.SelectedPeriodId;
                    var label = session.IsCurrent ? $"🔴 LIVE — {session.Label}" : session.Label;

                    <option value="@val" selected="@(isSelected ? "selected" : null)">@label</option>
                }
            </select>
        </div>

        <div class="col-md-6">
            <div class="text-muted small">
                Viewing Attendance for: <strong>@Model.SelectedDate.ToShortDateString()</strong>
            </div>
        </div>
    </form>
</div>

<script>
    function changeSession(selectObject) {
        var value = selectObject.value;
        var parts = value.split('_');
        var date = parts[0];
        var period = parts[1];
        window.location.href = `?id=@Model.ClassId&date=${date}&periodId=${period}`;
    }
</script>

<div class="container-fluid mt-3">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">@Model.ClassName</h2>
            <span class="text-muted">@Model.SubjectName &bull; @DateTime.Now.ToLongDateString()</span>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Exit</a>
    </div>

    <form asp-action="UpdateSession" method="post">
        <input type="hidden" asp-for="ClassId" />
        <input type="hidden" asp-for="SubjectId" />
        <input type="hidden" asp-for="SelectedDate" />
        <input type="hidden" asp-for="SelectedPeriodId" />

        <div class="card mb-3 border-primary shadow-sm">
            <div class="card-body py-2 bg-light d-flex align-items-center gap-3">
                <span class="fw-bold text-primary"><i class="bi bi-plus-circle"></i> New Grades:</span>

                <div class="d-flex align-items-center">
                    <label class="me-2 small">Type:</label>
                    <select asp-for="BatchGradeType" class="form-select form-select-sm"
                            asp-items="Html.GetEnumSelectList<GradeType>()"></select>
                </div>

                <div class="d-flex align-items-center flex-grow-1">
                    <label class="me-2 small">Desc:</label>
                    <input asp-for="BatchDescription" class="form-control form-control-sm" placeholder="e.g. Pop Quiz" />
                </div>
            </div>
        </div>

        <div class="card shadow-sm">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th style="width: 20%">Student</th>
                        <th style="width: 15%">Attendance (Today)</th>
                        <th style="width: 45%">Grade History</th>
                        <th style="width: 20%">Input New Grade</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < Model.Students.Count; i++)
                    {
                        <tr>
                            <input type="hidden" asp-for="Students[i].StudentId" />
                            <input type="hidden" asp-for="Students[i].StudentName" />

                            <td class="fw-bold">@Model.Students[i].StudentName</td>

                            <td>
                                <input type="hidden" id="attn_val_@i"
                                       name="Students[@i].AttendanceToday"
                                       value="@((int)Model.Students[i].AttendanceToday)" />

                                <button type="button" class="btn btn-sm w-100 fw-bold"
                                        id="attn_btn_@i"
                                        onclick="cycleAttendance(@i)">
                                    Loading...
                                </button>
                            </td>

                            <td>
                                <div class="d-flex flex-wrap gap-1">
                                    @foreach (var g in Model.Students[i].ExistingGrades)
                                    {
                                        var badgeColor = g.Value < 3 ? "bg-danger" : (g.Value >= 5 ? "bg-success" : "bg-primary");

                                        <a href="#" class="badge @badgeColor text-decoration-none"
                                           data-bs-toggle="modal" data-bs-target="#editGradeModal"
                                           onclick="openGradeModal(@g.Id, @g.Value, '@g.Type', '@g.Description', '@g.Date.ToShortDateString()', '@g.TeacherName')">
                                            @g.Value
                                        </a>
                                    }
                                </div>
                            </td>

                            <td>
                                <input asp-for="Students[i].NewGrade" type="number" step="0.25" min="2" max="6"
                                       class="form-control form-control-sm" placeholder="-" />
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="card-footer bg-white text-end sticky-bottom">
                <button type="submit" class="btn btn-primary btn-lg px-5">
                    <i class="bi bi-save-fill"></i> Save Session
                </button>
            </div>
        </div>
    </form>
</div>

<div class="modal fade" id="editGradeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="EditGrade" method="post">
                <div class="modal-header">
                    <h5 class="modal-title">Edit Grade Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="modalGradeId" name="GradeId" />
                    <input type="hidden" name="ReturnClassId" value="@Model.ClassId" />
                    <input type="hidden" name="ReturnDate" value="@Model.SelectedDate.ToString("yyyy-MM-dd")" />
                    <input type="hidden" name="ReturnPeriodId" value="@Model.SelectedPeriodId" />

                    <div class="alert alert-secondary py-2 small mb-3">
                        <div><strong>Given by:</strong> <span id="modalTeacher"></span></div>
                        <div><strong>Date:</strong> <span id="modalDate"></span></div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Grade Value</label>
                        <input type="number" step="0.25" min="2" max="6" class="form-control" id="modalValue" name="NewValue" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select class="form-select form-select-sm" id="modalType" name="NewType" asp-items="Html.GetEnumSelectList<GradeType>()"></select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input type="text" class="form-control" id="modalDesc" name="NewDescription" />
                    </div>

                </div>
                <div class="modal-footer justify-content-between">
                    <button type="submit" asp-action="DeleteGrade" class="btn btn-danger"
                            onclick="return confirm('Are you sure you want to delete this grade?');">
                        <i class="bi bi-trash"></i> Delete
                    </button>

                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg"></i> Update Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        @for (int i = 0; i < Model.Students.Count; i++)
        {
            <text>updateButtonVisuals(@i);</text>
        }
        });

        function cycleAttendance(index) {
            var input = document.getElementById("attn_val_" + index);
            var currentVal = parseInt(input.value);

            if (isNaN(currentVal)) currentVal = 0;

            // Cycle
            var newVal = (currentVal + 1) % 3;

            input.value = newVal;
            updateButtonVisuals(index);
        }

        function updateButtonVisuals(index) {
            var val = document.getElementById("attn_val_" + index).value;
            var btn = document.getElementById("attn_btn_" + index);

            if (val == "0") {
                btn.className = "btn btn-sm w-100 btn-outline-success"; 
                btn.innerHTML = "<i class='bi bi-check-circle-fill'></i> Present";
            } else if (val == "1") {
                btn.className = "btn btn-sm w-100 btn-danger"; 
                btn.innerHTML = "<i class='bi bi-x-circle-fill'></i> Absent";
            } else {
                btn.className = "btn btn-sm w-100 btn-warning text-dark"; 
                btn.innerHTML = "<i class='bi bi-clock-history'></i> Late";
            }
        }

        function openGradeModal(id, val, type, desc, date, teacher) {
            document.getElementById('modalGradeId').value = id;
            document.getElementById('modalValue').value = val;
            document.getElementById('modalDesc').value = desc;
            document.getElementById('modalDate').innerText = date;
            document.getElementById('modalTeacher').innerText = teacher;

            var select = document.getElementById('modalType');
            for(var i=0; i < select.options.length; i++) {
                if(select.options[i].text == type) {
                    select.selectedIndex = i;
                    break;
                }
            }
        }
    </script>
}