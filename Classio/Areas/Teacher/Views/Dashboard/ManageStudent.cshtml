@using Classio.Models
@using Classio.Areas.Teacher.Models
@model ManageStudentViewModel

@{
    ViewData["Title"] = Model.StudentName + " - " + Model.ClassName;
}

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">@Model.StudentName</h2>
            <span class="text-muted">Class @Model.ClassName</span>
        </div>
        <a asp-action="ManageClass" asp-route-id="@Model.ClassId" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to Class
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Stats row -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h3 class="fw-bold text-success">@(Model.OverallAverage > 0 ? Model.OverallAverage.ToString("0.00") : "-")</h3>
                    <small class="text-muted">Overall Average</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h3 class="fw-bold text-info">@Model.SubjectGrades.Sum(s => s.Grades.Count)</h3>
                    <small class="text-muted">Total Grades</small>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center shadow-sm">
                <div class="card-body">
                    <h3 class="fw-bold text-danger">@Model.WeightedAbsences.ToString("0.0")</h3>
                    <small class="text-muted">Weighted Absences</small>
                </div>
            </div>
        </div>
    </div>

    <!-- GRADES SECTION -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-journal-bookmark-fill text-primary me-2"></i>Grades</h4>
        <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addGradeModal">
            <i class="bi bi-plus-circle"></i> Add Grade
        </button>
    </div>

    @if (!Model.SubjectGrades.Any())
    {
        <div class="alert alert-info mb-4">No grades recorded yet.</div>
    }

    <div class="row g-4 mb-5">
        @foreach (var subject in Model.SubjectGrades)
        {
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
                        <h5 class="mb-0 fw-bold">@subject.SubjectName</h5>
                        <span class="badge bg-primary fs-6">Avg: @subject.Average.ToString("0.00")</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light small text-uppercase">
                                    <tr>
                                        <th class="ps-3" style="width: 20%">Date</th>
                                        <th style="width: 30%">Type & Details</th>
                                        <th style="width: 25%">Teacher</th>
                                        <th class="text-center" style="width: 10%">Grade</th>
                                        <th class="text-end pe-3" style="width: 15%">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in subject.Grades)
                                    {
                                        var badgeColor = g.Value < 3 ? "bg-danger" : g.Value >= 5 ? "bg-success" : "bg-primary";
                                        <tr>
                                            <td class="ps-3 text-muted small">@g.Date.ToShortDateString()</td>
                                            <td>
                                                <span class="badge bg-secondary me-1">@g.Type</span>
                                                <span class="small text-muted">@(g.Description ?? "")</span>
                                            </td>
                                            <td class="small text-muted">@g.TeacherName</td>
                                            <td class="text-center">
                                                <span class="badge @badgeColor fs-6">@g.Value</span>
                                            </td>
                                            <td class="text-end pe-3">
                                                <button class="btn btn-sm btn-outline-primary"
                                                        data-bs-toggle="modal" data-bs-target="#editGradeModal"
                                                        onclick="openEditGrade(@g.Id, @g.Value, '@g.Type', '@(g.Description?.Replace("'", "\\'") ?? "")', '@g.Date.ToShortDateString()', '@g.TeacherName')">
                                                    <i class="bi bi-pencil"></i>
                                                </button>
                                                <form asp-action="DeleteHomeroomGrade" method="post" class="d-inline">
                                                    <input type="hidden" name="GradeId" value="@g.Id" />
                                                    <input type="hidden" name="ReturnClassId" value="@Model.ClassId" />
                                                    <input type="hidden" name="ReturnStudentId" value="@Model.StudentId" />
                                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                                            onclick="return confirm('Delete this grade?')">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- ABSENCES SECTION -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0"><i class="bi bi-calendar-x text-danger me-2"></i>Absences</h4>
        <button class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#addAbsenceModal">
            <i class="bi bi-plus-circle"></i> Add Absence
        </button>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Date</th>
                        <th>Subject</th>
                        <th>Status</th>
                        <th class="text-center">Weight</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Absences.Any())
                    {
                        <tr><td colspan="5" class="text-center py-4 text-muted">No absences recorded.</td></tr>
                    }
                    @foreach (var a in Model.Absences)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@a.Date.ToShortDateString()</td>
                            <td>@a.SubjectName</td>
                            <td>
                                @if (a.State == AttendanceState.Late)
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-clock-history"></i> Late</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Absent</span>
                                }
                            </td>
                            <td class="text-center fw-bold">@a.Weight.ToString("0.0")</td>
                            <td class="text-end pe-4">
                                <form asp-action="DeleteHomeroomAbsence" method="post" class="d-inline">
                                    <input type="hidden" name="AbsenceId" value="@a.Id" />
                                    <input type="hidden" name="ReturnClassId" value="@Model.ClassId" />
                                    <input type="hidden" name="ReturnStudentId" value="@Model.StudentId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"
                                            onclick="return confirm('Remove this absence record?')">
                                        <i class="bi bi-trash"></i> Remove
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Grade Modal -->
<div class="modal fade" id="addGradeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddHomeroomGrade" method="post">
                <input type="hidden" name="StudentId" value="@Model.StudentId" />
                <input type="hidden" name="ClassId" value="@Model.ClassId" />

                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-plus-circle text-primary me-2"></i>Add Grade</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <select name="SubjectId" class="form-select" id="addGradeSubject" onchange="filterTeachers()">
                            @foreach (var s in Model.AvailableSubjects)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Teacher</label>
                        <select name="TeacherId" class="form-select" id="addGradeTeacher">
                            @foreach (var t in Model.AvailableTeachers)
                            {
                                <option value="@t.Id" data-subject="@t.SubjectId">@t.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Grade Value</label>
                        <input type="number" step="0.25" min="2" max="6" class="form-control" name="Value" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select class="form-select" name="Type" asp-items="Html.GetEnumSelectList<GradeType>()"></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input type="text" class="form-control" name="Description" placeholder="Optional" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Add Grade</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Edit Grade Modal -->
<div class="modal fade" id="editGradeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="EditHomeroomGrade" method="post">
                <input type="hidden" id="editGradeId" name="GradeId" />
                <input type="hidden" name="ReturnClassId" value="@Model.ClassId" />
                <input type="hidden" name="ReturnStudentId" value="@Model.StudentId" />

                <div class="modal-header">
                    <h5 class="modal-title">Edit Grade</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="alert alert-secondary py-2 small mb-3">
                        <div><strong>Given by:</strong> <span id="editTeacher"></span></div>
                        <div><strong>Date:</strong> <span id="editDate"></span></div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Grade Value</label>
                        <input type="number" step="0.25" min="2" max="6" class="form-control" id="editValue" name="NewValue" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Type</label>
                        <select class="form-select" id="editType" name="NewType" asp-items="Html.GetEnumSelectList<GradeType>()"></select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <input type="text" class="form-control" id="editDesc" name="NewDescription" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success"><i class="bi bi-check-lg"></i> Save Changes</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Absence Modal -->
<div class="modal fade" id="addAbsenceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-action="AddHomeroomAbsence" method="post">
                <input type="hidden" name="StudentId" value="@Model.StudentId" />
                <input type="hidden" name="ClassId" value="@Model.ClassId" />

                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-calendar-x text-danger me-2"></i>Add Absence</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Date</label>
                        <input type="date" class="form-control" name="Date" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Subject</label>
                        <select name="SubjectId" class="form-select">
                            @foreach (var s in Model.AvailableSubjects)
                            {
                                <option value="@s.Id">@s.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Status</label>
                        <select name="State" class="form-select">
                            <option value="1">Absent</option>
                            <option value="2">Late</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger"><i class="bi bi-check-lg"></i> Add Absence</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openEditGrade(id, val, type, desc, date, teacher) {
            document.getElementById('editGradeId').value = id;
            document.getElementById('editValue').value = val;
            document.getElementById('editDesc').value = desc;
            document.getElementById('editDate').innerText = date;
            document.getElementById('editTeacher').innerText = teacher;

            var select = document.getElementById('editType');
            for (var i = 0; i < select.options.length; i++) {
                if (select.options[i].text === type) {
                    select.selectedIndex = i;
                    break;
                }
            }
        }

        function filterTeachers() {
            var subjectId = document.getElementById('addGradeSubject').value;
            var teacherSelect = document.getElementById('addGradeTeacher');
            var firstVisible = null;

            for (var i = 0; i < teacherSelect.options.length; i++) {
                var opt = teacherSelect.options[i];
                var match = opt.getAttribute('data-subject') === subjectId;
                opt.hidden = !match;
                if (match && !firstVisible) firstVisible = opt;
            }

            if (firstVisible) firstVisible.selected = true;
        }

        document.addEventListener('DOMContentLoaded', filterTeachers);
    </script>
}
