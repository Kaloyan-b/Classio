@model Classio.Areas.Student.Models.StudentDashboardViewModel

@{
    ViewData["Title"] = Model.StudentName + " - Overview";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0" style="color: #E76F51;">@Model.StudentName</h2>
            <p class="text-muted mb-0">Student Overview</p>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <a asp-action="ChildGrades" asp-route-studentId="@ViewBag.StudentId" class="text-decoration-none">
                <div class="glass-card-light h-100 p-4 text-center border-0 shadow-sm hover-zoom">
                    <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 60px; height: 60px; background: rgba(244, 162, 97, 0.15);">
                        <i class="bi bi-mortarboard fs-2" style="color: #F4A261;"></i>
                    </div>
                    <h3 class="display-5 fw-bold" style="color: #264653;">@Model.OverallAverage.ToString("0.00")</h3>
                    <p class="text-muted mb-0">Overall Average</p>
                </div>
            </a>
        </div>

        <div class="col-md-4">
            <div class="glass-card-light h-100 p-4 text-center border-0 shadow-sm">
                <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 60px; height: 60px; background: rgba(42, 157, 143, 0.15);">
                    <i class="bi bi-trophy fs-2" style="color: #2A9D8F;"></i>
                </div>
                <h3 class="display-5 fw-bold" style="color: #264653;">@Model.FormattedRank</h3>
                <p class="text-muted mb-0">Out of @Model.TotalStudents Students</p>
            </div>
        </div>

        <div class="col-md-4">
            <a asp-action="ChildAttendance" asp-route-studentId="@ViewBag.StudentId" class="text-decoration-none">
                <div class="glass-card-light h-100 p-4 text-center border-0 shadow-sm hover-zoom">
                    <div class="rounded-circle d-inline-flex justify-content-center align-items-center mb-3" style="width: 60px; height: 60px; background: rgba(231, 111, 81, 0.15);">
                        <i class="bi bi-calendar-x fs-2" style="color: #E76F51;"></i>
                    </div>
                    <h3 class="display-5 fw-bold" style="color: #264653;">@Model.WeightedAbsences</h3>
                    <p class="text-muted mb-0">Weighted Absences</p>
                </div>
            </a>
        </div>
    </div>
</div>

<style>
    .hover-zoom {
        transition: transform 0.2s ease-in-out;
        cursor: pointer;
    }

        .hover-zoom:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.12) !important;
        }
</style>
