@model Classio.Areas.Student.Models.StudentGradesViewModel

@{
    ViewData["Title"] = "My Grades";
}

<div class="container py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i> Back</a>
        <h2 class="mb-0">Academic Performance</h2>
    </div>

    @if (!Model.Subjects.Any())
    {
        <div class="alert alert-info">No grades have been recorded yet.</div>
    }

    <div class="row g-4">
        @foreach (var subject in Model.Subjects)
        {
            <div class="col-12 col-lg-6">
                <div class="card shadow-sm h-100">
                    <div class="card-header bg-light d-flex justify-content-between align-items-center py-3">
                        <h5 class="mb-0 fw-bold">@subject.SubjectName</h5>
                        <span class="badge bg-primary fs-6">Avg: @subject.AverageGrade.ToString("0.00")</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light small text-uppercase">
                                    <tr>
                                        <th class="ps-3" style="width: 25%">Date</th>
                                        <th style="width: 55%">Type & Details</th>
                                        <th class="text-end pe-3" style="width: 20%">Grade</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var g in subject.Grades)
                                    {
                                        <tr>
                                            <td class="ps-3 text-muted">@g.Date.ToShortDateString()</td>
                                            <td>
                                                <span class="badge bg-secondary me-1">@g.Type</span>
                                                <span class="small">@(string.IsNullOrEmpty(g.Description) ? "" : g.Description)</span>
                                            </td>
                                            <td class="text-end pe-3 fw-bold fs-5">@g.Value</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>