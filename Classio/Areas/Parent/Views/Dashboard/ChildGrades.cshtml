@model Classio.Areas.Student.Models.StudentGradesViewModel

@{
    ViewData["Title"] = "Grades";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0" style="color: #E76F51;">
                <i class="bi bi-journal-bookmark-fill me-2"></i>Academic Performance
            </h2>
            <p class="text-muted mb-0">Grades by subject</p>
        </div>
        <a asp-action="ChildDetails" asp-route-studentId="@ViewBag.StudentId" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-1"></i> Back
        </a>
    </div>

    @if (!Model.Subjects.Any())
    {
        <div class="glass-card-light p-5 text-center shadow-sm border-0">
            <i class="bi bi-journal-x display-1 mb-3 opacity-50" style="color: #F4A261;"></i>
            <h3 class="fw-bold" style="color: #333;">No grades recorded yet</h3>
            <p class="text-muted">Grades will appear here once they are entered by teachers.</p>
        </div>
    }

    <div class="row g-4">
        @foreach (var subject in Model.Subjects)
        {
            <div class="col-12 col-lg-6">
                <div class="glass-card-light h-100 p-0 border-0 shadow-sm overflow-hidden">
                    <div class="d-flex justify-content-between align-items-center py-3 px-4" style="background: rgba(244, 162, 97, 0.1); border-bottom: 1px solid rgba(244, 162, 97, 0.2);">
                        <h5 class="mb-0 fw-bold" style="color: #264653;">@subject.SubjectName</h5>
                        <span class="badge fs-6 fw-bold" style="background-color: #F4A261;">
                            Avg: @subject.AverageGrade.ToString("0.00")
                        </span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead>
                                <tr style="background: rgba(38, 70, 83, 0.04);">
                                    <th class="ps-4 small text-uppercase fw-bold" style="color: #264653; width: 25%;">Date</th>
                                    <th class="small text-uppercase fw-bold" style="color: #264653; width: 55%;">Type & Details</th>
                                    <th class="text-end pe-4 small text-uppercase fw-bold" style="color: #264653; width: 20%;">Grade</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var g in subject.Grades)
                                {
                                    var gradeColor = g.Value >= 5 ? "#2A9D8F" : g.Value >= 3.5 ? "#F4A261" : "#E76F51";
                                    <tr>
                                        <td class="ps-4 text-muted">@g.Date.ToShortDateString()</td>
                                        <td>
                                            <span class="badge me-1" style="background-color: #264653;">@g.Type</span>
                                            <span class="small text-muted">@(string.IsNullOrEmpty(g.Description) ? "" : g.Description)</span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <span class="fw-bold fs-5" style="color: @gradeColor;">@g.Value</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
