@model IEnumerable<Classio.Models.Class>

@{
    ViewData["Title"] = "Manage Schedules";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0" style="color: #E76F51;">Manage Schedules</h2>
            <p class="text-muted">Select a class below to edit its weekly schedule.</p>
        </div>
    </div>

    <div class="glass-card-light border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle" style="background: transparent;">
                <thead style="background: rgba(231, 111, 81, 0.05);">
                    <tr>
                        <th class="py-3 px-4 fw-bold" style="color: #264653;">Class</th>
                        <th class="py-3 px-4 fw-bold text-end" style="color: #264653;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="2" class="text-center py-5 text-muted">
                                No classes found. Please create a class first.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                                <td class="py-3 px-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-white rounded-circle d-flex justify-content-center align-items-center shadow-sm me-3" style="width: 40px; height: 40px; border: 2px solid #F4A261;">
                                            <i class="bi bi-calendar-week" style="color: #E76F51;"></i>
                                        </div>
                                        <span class="fw-bold" style="color: #333;">@item.Name</span>
                                    </div>
                                </td>
                                <td class="py-3 px-4 text-end">
                                    <a asp-action="Manage" asp-route-id="@item.Id"
                                       class="btn btn-sm fw-bold px-3 py-1 shadow-sm" style="background-color: #F4A261; color: white; border-radius: 8px;">
                                        <i class="bi bi-calendar-week me-1"></i> Edit Schedule
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
