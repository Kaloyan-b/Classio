@model List<Classio.Models.ScheduleSlot>
@{
    ViewData["Title"] = "Schedule: " + ViewBag.ClassName;
    var days = new[] { DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday };
}

<div class="py-4">
    <div class="d-flex align-items-center mb-4">
        <a asp-action="Index" class="btn btn-outline-custom rounded-circle me-3" style="width: 45px; height: 45px; display: flex; align-items: center; justify-content: center;">
            <i class="bi bi-arrow-left fs-5"></i>
        </a>
        <div>
            <h2 class="fw-bold mb-0" style="color: #E76F51;">Schedule: @ViewBag.ClassName</h2>
            <p class="text-muted mb-0">Drag subjects from the sidebar to assign them. Click a slot to change its teacher.</p>
        </div>
    </div>

    <div class="row g-0">
        <!-- Subject sidebar -->
        <div class="col-md-2">
            <div class="glass-card-light border-0 shadow-sm p-3 h-100">
                <h6 class="fw-bold mb-3" style="color: #264653;"><i class="bi bi-book-half me-1"></i> Subjects</h6>
                <div id="subject-pool">
                    @foreach (var subject in ViewBag.Subjects)
                    {
                        <div class="card mb-2 p-2 shadow-sm draggable-subject"
                             draggable="true"
                             data-id="@subject.Id"
                             style="cursor: grab; border-left: 4px solid #E76F51; border-radius: 6px; font-size: 0.9rem;">
                            @subject.Name
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Schedule grid -->
        <div class="col-md-10 ps-3">
            <div class="glass-card-light border-0 shadow-sm overflow-hidden">
                <table class="table table-bordered text-center align-middle mb-0" style="background: transparent;">
                    <thead style="background: rgba(231, 111, 81, 0.1);">
                        <tr>
                            <th class="py-3 fw-bold" style="color: #264653; width: 100px;">Time</th>
                            @foreach (var day in days)
                            {
                                <th class="py-3 fw-bold" style="color: #264653;">@day</th>
                            }
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var period in ViewBag.Periods)
                        {
                            if (period.IsBreak)
                            {
                                <tr style="background: rgba(244, 162, 97, 0.08);">
                                    <td class="fw-bold small" style="color: #E76F51;">@period.Name</td>
                                    <td colspan="5" class="small text-muted">@period.StartTime - @period.EndTime</td>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td class="fw-bold" style="background: rgba(231, 111, 81, 0.04);">
                                        <div class="small" style="color: #264653;">@period.Name</div>
                                        <span class="small text-muted">@period.StartTime.ToString(@"hh\:mm")</span>
                                    </td>
                                    @foreach (var day in days)
                                    {
                                        var slot = Model.FirstOrDefault(s => s.ClassPeriodId == period.Id && s.DayOfWeek == day);

                                        <td class="drop-zone position-relative"
                                            data-period-id="@period.Id"
                                            data-day="@((int)day)"
                                            ondrop="drop(event)"
                                            ondragover="allowDrop(event)"
                                            style="height: 80px; vertical-align: top;">

                                            @if (slot != null)
                                            {
                                                <div class="badge w-100 p-2 mt-1 shadow-sm text-wrap"
                                                     style="cursor: pointer; background-color: #E76F51;"
                                                     onclick="openEditModal(@slot.SubjectId, @period.Id, @((int)day))">

                                                    <div class="fs-6">@slot.Subject.Name</div>
                                                    <div class="fw-light small">
                                                        <i class="bi bi-person"></i> @slot.Teacher?.LastName
                                                        <i class="bi bi-pencil-square ms-1"></i>
                                                    </div>
                                                </div>
                                            }
                                        </td>
                                    }
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- Teacher selection modal -->
<div class="modal fade" id="teacherModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header" style="background: rgba(231, 111, 81, 0.05);">
                <h5 class="modal-title fw-bold" style="color: #264653;">Change Teacher</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editSubjectId">
                <input type="hidden" id="editPeriodId">
                <input type="hidden" id="editDay">

                <label class="form-label fw-bold" style="color: #264653;">Select Teacher:</label>
                <select id="teacherSelect" class="form-select mb-3"></select>

                <button class="btn w-100 fw-bold text-white" style="background-color: #E76F51; border-radius: 8px;" onclick="saveManualAssignment()">Save Change</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.draggable-subject').forEach(item => {
        item.addEventListener('dragstart', ev => {
            ev.dataTransfer.setData("subjectId", ev.target.dataset.id);
        });
    });

    function allowDrop(ev) {
        ev.preventDefault();
        const cell = ev.target.closest('td');
        if(cell) cell.style.backgroundColor = "rgba(244, 162, 97, 0.15)";
    }

    function drop(ev) {
        ev.preventDefault();
        const cell = ev.target.closest('td');
        cell.style.backgroundColor = "";

        const subjectId = ev.dataTransfer.getData("subjectId");
        const periodId = cell.getAttribute('data-period-id');
        const day = cell.getAttribute('data-day');

        performSave(periodId, day, subjectId, 0);
    }

    function openEditModal(subjectId, periodId, day) {
        document.getElementById('editSubjectId').value = subjectId;
        document.getElementById('editPeriodId').value = periodId;
        document.getElementById('editDay').value = day;

        const modal = new bootstrap.Modal(document.getElementById('teacherModal'));
        modal.show();

        const select = document.getElementById('teacherSelect');
        select.innerHTML = "<option>Loading...</option>";
        select.disabled = true;

        fetch(`/Admin/Schedule/GetTeachersForSubject?subjectId=${subjectId}`)
            .then(res => res.json())
            .then(data => {
                select.innerHTML = "";
                data.forEach(t => {
                    let opt = document.createElement('option');
                    opt.value = t.id;
                    opt.text = t.name;
                    select.add(opt);
                });
                select.disabled = false;
            });
    }

    function saveManualAssignment() {
        const subjectId = document.getElementById('editSubjectId').value;
        const periodId = document.getElementById('editPeriodId').value;
        const day = document.getElementById('editDay').value;
        const teacherId = document.getElementById('teacherSelect').value;

        performSave(periodId, day, subjectId, teacherId);
    }

    function performSave(periodId, day, subjectId, teacherId) {
        const payload = {
            ClassId: @ViewBag.ClassId,
            PeriodId: parseInt(periodId),
            Day: parseInt(day),
            SubjectId: parseInt(subjectId),
            TeacherId: parseInt(teacherId)
        };

        fetch('/Admin/Schedule/UpdateSlot', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(res => {
            if(res.ok) {
                location.reload();
            } else {
                return res.json().then(err => alert("Error: " + err.message));
            }
        });
    }
</script>
