@model List<Classio.Models.ScheduleSlot>
@{
    var days = new[] { DayOfWeek.Monday, DayOfWeek.Tuesday, DayOfWeek.Wednesday, DayOfWeek.Thursday, DayOfWeek.Friday };
}

<div class="container-fluid mt-3">
    <div class="row">

        <div class="col-md-2 bg-light p-3 border-end" style="height: 90vh;">
            <h5>Subjects</h5>
            <p class="text-muted small">Drag these to the grid</p>

            @foreach (var subject in ViewBag.Subjects)
            {
                <div class="card mb-2 p-2 shadow-sm draggable-subject"
                     draggable="true"
                     data-id="@subject.Id"
                     style="cursor: grab; border-left: 4px solid #007bff;">
                    @subject.Name
                </div>
            }
        </div>

        <div class="col-md-10 p-3">
            <h2>Schedule: @ViewBag.ClassName</h2>

            <table class="table table-bordered text-center align-middle">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 150px;">Time</th>
                        <th>Mon</th>
                        <th>Tue</th>
                        <th>Wed</th>
                        <th>Thu</th>
                        <th>Fri</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var period in ViewBag.Periods)
                    {
                        if (period.IsBreak)
                        {
                            <tr class="table-secondary">
                                <td class="fw-bold">@period.Name</td>
                                <td colspan="5" class="text-muted small">
                                    @period.StartTime.ToString(@"hh\:mm") - @period.EndTime.ToString(@"hh\:mm")
                                </td>
                            </tr>
                        }
                        else
                        {
                            <tr>
                                <td class="bg-light fw-bold">
                                    <div class="small">@period.Name</div>
                                    @period.StartTime.ToString(@"hh\:mm") - @period.EndTime.ToString(@"hh\:mm")
                                </td>

                                @foreach (var day in days)
                                {

                                    var slot = Model.FirstOrDefault(s => s.ClassPeriodId == period.Id && s.DayOfWeek == day);

                                    <td class="drop-zone"
                                        data-period-id="@period.Id"
                                        data-day="@((int)day)"
                                        ondrop="drop(event)"
                                        ondragover="allowDrop(event)"
                                        style="height: 80px; vertical-align: top;">

                                        @if (slot != null)
                                        {
                                            <div class="badge bg-primary w-100 p-2 mt-1">
                                                @slot.Subject.Name <br />
                                                <small>@slot.Teacher?.LastName</small>
                                            </div>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // Setup Draggable
        const draggables = document.querySelectorAll('.draggable-subject');

        draggables.forEach(item => {
            item.addEventListener('dragstart', function(ev) {
                const subjectId = ev.target.getAttribute('data-id');
                console.log("Started dragging Subject ID:", subjectId);

                ev.dataTransfer.setData("subjectId", subjectId);
                ev.dataTransfer.effectAllowed = "copy"; // Tell browser this is a copy
            });
        });
    });

    // Allow Drop 
    function allowDrop(ev) {
        ev.preventDefault(); // Stop snap back
        ev.dataTransfer.dropEffect = "copy"; // 

        const cell = ev.target.closest('td');
        if (cell) cell.style.background = "#e9ecef";
    }

    // Drop
    function drop(ev) {
        ev.preventDefault(); 
        console.log("Drop event fired!");

        const cell = ev.target.closest('td');

        if (!cell) {
            console.error("Dropped on something that isn't a cell!");
            return;
        }

        cell.style.background = "";

        const subjectId = ev.dataTransfer.getData("subjectId");
        const periodId = cell.getAttribute('data-period-id');
        const day = cell.getAttribute('data-day');

        console.log(`Dropping Subject ${subjectId} onto Period ${periodId}, ${day}`);

        //Validate
        if (!subjectId || !periodId || !day) {
            console.error("Missing data!", { subjectId, periodId, day });
            alert("Error: Could not read drop data.");
            return;
        }

        // Prepare Data for API
        const payload = {
            ClassId: @ViewBag.ClassId,
            PeriodId: parseInt(periodId),
            Day: parseInt(day), 
            SubjectId: parseInt(subjectId)
        };

        // Send to Server
        fetch('/Admin/Schedule/UpdateSlot', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json'
            },
            body: JSON.stringify(payload)
        })
        .then(response => {
            if (response.ok) {
                console.log("Saved successfully!");
                location.reload();
            } else {
                console.error("Server Error:", response);
                alert("Server failed to save.");
            }
        })
        .catch(error => console.error("Network Error:", error));
    }
</script>