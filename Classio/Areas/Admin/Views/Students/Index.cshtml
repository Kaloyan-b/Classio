@model IEnumerable<Classio.Models.Student>

@{
    ViewData["Title"] = "Manage Students";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Manage Students</h1>
    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#studentModal"
            onclick="loadModal('@Url.Action("Create", "Students", new { area = "Admin" })', 'studentModalContent')">
        <i class="bi bi-person-plus-fill"></i> Add Student
    </button>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table-responsive table table-striped table-hover mb-0 align-middle ">
                <thead class="table-dark">
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Class</th>
                        <th>Parents</th>
                        <th>School</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">
                                <div class="d-flex align-items-center">
                                    <div class="bg-secondary text-white rounded-circle d-flex justify-content-center align-items-center me-2" style="width: 32px; height: 32px; font-size: 0.8rem;">
                                        @item.FirstName.Substring(0, 1)@item.LastName.Substring(0, 1)
                                    </div>
                                    @item.FirstName @item.LastName
                                </div>
                            </td>

                            <td>
                                @if (item.User != null)
                                {
                                    <a href="mailto:@item.User.Email" class="text-decoration-none">@item.User.Email</a>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">No User Account</span>
                                }
                            </td>

                            <td>
                                @if (item.Class != null)
                                {
                                    <span class="badge bg-info text-dark">@item.Class.Name</span>
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Unassigned</span>
                                }
                            </td>

                            <td class="small">
                                @if (item.Parent1 != null && item.Parent1.User != null)
                                {
                                    <div><i class="bi bi-person"></i> @item.Parent1.FirstName @item.Parent1.User.LastName</div>
                                }
                                @if (item.Parent2 != null && item.Parent2.User != null)
                                {
                                    <div><i class="bi bi-person"></i> @item.Parent2.User.FirstName @item.Parent2.User.LastName</div>
                                }
                                @if (item.Parent1 == null && item.Parent2 == null)
                                {
                                    <span class="text-center text-center">-</span>
                                }
                            </td>
                            <td>
                                @(item.School?.Name ?? "N/A")
                            </td>

                           @*  <td class="text-center">
                                @if (item.Absences != null && item.Absences.Count > 0)
                                {
                                    <span class="badge bg-danger rounded-pill">@item.Absences.Count</span>
                                }
                                else
                                {
                                    <span class="text-muted">-</span>
                                }
                            </td> *@

                            <td class="text-center">
                                <div class="btn-group" role="group">
                                    <button type="button" class="btn btn-sm btn-outline-primary" data-bs-toggle="modal" data-bs-target="#studentModal"
                                            onclick="loadModal('@Url.Action("Edit", "Students", new { area = "Admin", id = item.Id })', 'studentModalContent')">
                                        <i class="bi bi-pencil"></i> Edit
                                    </button>

                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Are you sure you want to delete this student?');">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="studentModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" id="studentModalContent">
            <div class="modal-body text-center py-5">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // load partial views into the modal
        function loadModal(url, targetId) {
            // loading spinner before request finishes
            $('#' + targetId).html('<div class="modal-body text-center py-4"><div class="spinner-border text-primary"></div></div>');

            $.get(url, function (data) {
                $('#' + targetId).html(data);
            }).fail(function() {
                $('#' + targetId).html('<div class="modal-body text-danger">Error loading form. Please try again.</div>');
            });
        }
    </script>
}