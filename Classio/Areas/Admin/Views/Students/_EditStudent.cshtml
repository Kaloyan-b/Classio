@model Classio.Areas.Admin.Models.EditStudentViewModel

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="modal-header" style="background: rgba(231, 111, 81, 0.05); border-bottom: 1px solid rgba(231, 111, 81, 0.15);">
        <h5 class="modal-title fw-bold" style="color: #E76F51;"><i class="bi bi-pencil-square me-2"></i>Edit Student</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <div class="modal-body p-4">
        <div class="row g-3 mb-3">
            <div class="col-md-6">
                <label asp-for="FirstName" class="form-label fw-bold" style="color: #264653;">First Name</label>
                <input asp-for="FirstName" class="form-control" />
                <span asp-validation-for="FirstName" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="LastName" class="form-label fw-bold" style="color: #264653;">Last Name</label>
                <input asp-for="LastName" class="form-control" />
                <span asp-validation-for="LastName" class="text-danger small"></span>
            </div>
        </div>

        <div class="mb-4">
            <label asp-for="Email" class="form-label fw-bold" style="color: #264653;">Email</label>
            <input asp-for="Email" class="form-control" />
            <span asp-validation-for="Email" class="text-danger small"></span>
        </div>

        <div class="p-3 rounded mb-4" style="background: rgba(244, 162, 97, 0.08); border: 1px solid rgba(244, 162, 97, 0.25);">
            <label class="form-label fw-bold" style="color: #E76F51;"><i class="bi bi-building me-1"></i> School & Class</label>

            <div class="mb-3">
                <label asp-for="SchoolId" class="form-label small fw-bold" style="color: #264653;">School</label>
                <select asp-for="SchoolId" class="form-select" asp-items="ViewBag.SchoolId"></select>
                <span asp-validation-for="SchoolId" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="ClassId" class="form-label small fw-bold" style="color: #264653;">Assign Class</label>
                <select asp-for="ClassId" class="form-select" asp-items="ViewBag.ClassId">
                    <option value="">-- No Class Assigned --</option>
                </select>
            </div>
        </div>

        <div class="p-3 rounded" style="background: rgba(244, 162, 97, 0.08); border: 1px solid rgba(244, 162, 97, 0.25);">
            <label class="form-label fw-bold" style="color: #E76F51;"><i class="bi bi-people-fill me-1"></i> Parents</label>

            <div class="mb-3">
                <label asp-for="Parent1Id" class="form-label small fw-bold" style="color: #264653;">Primary Parent</label>
                <select asp-for="Parent1Id" class="form-select" asp-items="ViewBag.ParentId">
                    <option value="">-- Select Parent --</option>
                </select>
            </div>

            <div>
                <label asp-for="Parent2Id" class="form-label small fw-bold" style="color: #264653;">Secondary Parent</label>
                <select asp-for="Parent2Id" class="form-select" asp-items="ViewBag.ParentId">
                    <option value="">-- Select Parent --</option>
                </select>
            </div>
        </div>
    </div>

    <div class="modal-footer" style="border-top: 1px solid rgba(231, 111, 81, 0.15);">
        <button type="button" class="btn btn-light fw-bold text-muted border" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn fw-bold text-white shadow-sm" style="background-color: #E76F51; border-radius: 8px;">Save Changes</button>
    </div>
</form>
