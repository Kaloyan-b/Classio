@model IEnumerable<Classio.Models.Class>

@{
    ViewData["Title"] = "Manage Classes";
}

<div class="py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0" style="color: #E76F51;">Manage Classes</h2>
            <p class="text-muted">View and organize all classes and head teacher assignments.</p>
        </div>
        <button type="button" class="btn fw-bold px-4 py-2 shadow-sm" style="background-color: #F4A261; color: white; border-radius: 8px;" data-bs-toggle="modal" data-bs-target="#createClassModal"
                onclick="loadModal('@Url.Action("Create", "Classes", new { area = "Admin" })', 'createClassModalContent')">
            <i class="bi bi-plus-lg me-1"></i> Add Class
        </button>
    </div>

    <div class="glass-card-light border-0 shadow-sm overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle" style="background: transparent;">
                <thead style="background: rgba(231, 111, 81, 0.05);">
                    <tr>
                        <th class="py-3 px-4 fw-bold" style="color: #264653;">Name</th>
                        <th class="py-3 px-4 fw-bold" style="color: #264653;">School</th>
                        <th class="py-3 px-4 fw-bold" style="color: #264653;">Head Teacher</th>
                        <th class="py-3 px-4 fw-bold text-end" style="color: #264653;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                No classes found in the system.
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr style="border-bottom: 1px solid rgba(0,0,0,0.05);">
                                <td class="py-3 px-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-white rounded-circle d-flex justify-content-center align-items-center shadow-sm me-3" style="width: 40px; height: 40px; border: 2px solid #F4A261;">
                                            <i class="bi bi-collection-fill" style="color: #E76F51;"></i>
                                        </div>
                                        <span class="fw-bold" style="color: #333;">@item.Name</span>
                                    </div>
                                </td>
                                <td class="py-3 px-4 text-muted">@(item.School?.Name ?? "N/A")</td>
                                <td class="py-3 px-4">
                                    @if (item.HeadTeacher != null)
                                    {
                                        <span class="badge rounded-pill" style="background-color: #E76F51; font-size: 0.85rem;">
                                            @item.HeadTeacher.FirstName @item.HeadTeacher.LastName
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted fst-italic small">None assigned</span>
                                    }
                                </td>
                                <td class="py-3 px-4 text-end">
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="createClassModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" id="createClassModalContent">
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function loadModal(url, targetId) {
            $.get(url, function (data) {
                $('#' + targetId).html(data);
            });
        }
    </script>
}
