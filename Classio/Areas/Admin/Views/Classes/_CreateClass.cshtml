@model Classio.Areas.Admin.Models.CreateClassViewModel

<form asp-action="Create" method="post">
    <div class="modal-header">
        <h5 class="modal-title">Add New Class</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <div class="modal-body">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="e.g. 10A, 5B" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="SchoolId" class="form-label"></label>
            <select asp-for="SchoolId" class="form-select" asp-items="ViewBag.SchoolId">
                <option value="" disabled selected>-- Select School --</option>
            </select>
            <span asp-validation-for="SchoolId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="HeadTeacherId" class="form-label"></label>
            <select asp-for="HeadTeacherId" class="form-select" asp-items="ViewBag.HeadTeacherId">
                <option value="">-- No Head Teacher (Yet) --</option>
            </select>
            <span asp-validation-for="HeadTeacherId" class="text-danger"></span>
        </div>
    </div>

    <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-primary">Create Class</button>
    </div>
</form>