@model Classio.Areas.Admin.Models.CreateClassViewModel

<form asp-action="Create" method="post">
    <div class="modal-header" style="background: rgba(231, 111, 81, 0.05); border-bottom: 1px solid rgba(231, 111, 81, 0.15);">
        <h5 class="modal-title fw-bold" style="color: #E76F51;"><i class="bi bi-plus-lg me-2"></i>Add New Class</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <div class="modal-body p-4">
        <div class="mb-3">
            <label asp-for="Name" class="form-label fw-bold" style="color: #264653;">Class Name</label>
            <input asp-for="Name" class="form-control" placeholder="e.g. 10A, 5B" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>

        <div class="p-3 rounded" style="background: rgba(244, 162, 97, 0.08); border: 1px solid rgba(244, 162, 97, 0.25);">
            <label class="form-label fw-bold" style="color: #E76F51;"><i class="bi bi-building me-1"></i> Assignment</label>

            <div class="mb-3">
                <label asp-for="SchoolId" class="form-label small fw-bold" style="color: #264653;">School</label>
                <select asp-for="SchoolId" class="form-select" asp-items="ViewBag.SchoolId">
                    <option value="" disabled selected>-- Select School --</option>
                </select>
                <span asp-validation-for="SchoolId" class="text-danger small"></span>
            </div>

            <div>
                <label asp-for="HeadTeacherId" class="form-label small fw-bold" style="color: #264653;">Head Teacher</label>
                <select asp-for="HeadTeacherId" class="form-select" asp-items="ViewBag.HeadTeacherId">
                    <option value="">-- No Head Teacher (Yet) --</option>
                </select>
                <span asp-validation-for="HeadTeacherId" class="text-danger small"></span>
            </div>
        </div>
    </div>

    <div class="modal-footer" style="border-top: 1px solid rgba(231, 111, 81, 0.15);">
        <button type="button" class="btn btn-light fw-bold text-muted border" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn fw-bold text-white shadow-sm" style="background-color: #E76F51; border-radius: 8px;">Create Class</button>
    </div>
</form>
