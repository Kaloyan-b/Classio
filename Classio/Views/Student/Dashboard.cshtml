@model Classio.ViewModels.StudentDashboardViewModel

@{
    ViewData["Title"] = "Страница на ученика";
} 

<style>

    .dashboard-container {
    max-width: 1200px;
    margin: 40px auto;
    padding: 20px;
    }

    .card {

    border-radius: 10px;
    padding: 20px;
    margin-bottom: 25px;
    }

    .card h3 {
    margin-bottom: 15px;
    }

    .grade-item, .absence-item {
    padding: 8px;
    border-radius: 6px;
    margin-bottom: 6px;
    }

    .flex-row {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    }

    .flex-col {
    flex: 1;
    min-width: 280px;
    }

    a.info-btn {
    display: inline-block;
    padding: 10px 18px;
    border-radius: 8px;
    text-decoration: none;
    margin-top: 10px;
    transition: 0.2s;
    }


</style>


<div class="dashboard-container">
    <h1>Здравей, @Model.StudentName!</h1>
    <p>@Model.ClassName – клас</p>

    <div class="flex-row">

        <!-- GRADES -->
        <div class="flex-col">
            <div class="card">
                <h3>Оценки</h3>

                @if (Model.Grades.Any())
                {
                    var groupedGrades = Model.Grades
                        .GroupBy(s => s.SubjectName)
                        .ToList();
                    foreach (var g in groupedGrades)
                    {
                        <div class="grade-item">
                            <strong>@g.Key:</strong>
                        </div>
                    }
                    //TODO: FINISH
                }
                else
                {
                    <p>Няма въведени оценки.</p>
                }

                <a class="info-btn" href="/Student/Grades">Всички оценки</a>
            </div>
        </div>

        <!-- ABSENCES -->
        <div class="flex-col">
            <div class="card">
                <h3>Отсъствия - @Model.Absences.Count</h3> 

                @if (Model.Absences.Any())
                {
                    var groupedAbsences = Model.Absences
                        .GroupBy(s => s.SubjectName)
                        .ToList();

                    foreach (var group in groupedAbsences)
                    {
                        <div class="absence-item">
                            <strong>@group.Key:</strong> @group.Count()
                            @* <div style="font-size: 12px; opacity: 0.7;">
                                @string.Join(", ", group.Select(a => a.Date.ToShortDateString()))
                            </div> *@
                        </div>
                    }
                }
                else
                {
                    <p>Няма отсъствия.</p>
                }

                <a class="info-btn" href="/Student/Absences">Всички отсъствия</a>
            </div>
        </div>

    </div>

    <!-- SCHEDULE -->
    <div class="card">
        <h3>Разписание</h3>

        @if (Model.Schedule.Any())
        {
            foreach (var s in Model.Schedule)
            {
                <div class="grade-item">
                    <strong>@s.Day:</strong> @s.SubjectName – @s.Hour ч.
                </div>
            }
        }
        else
        {
            <p>Няма добавено разписание.</p>
        }

        <a class="info-btn" href="/Student/Schedule">Пълно разписание</a>
    </div>

</div>
