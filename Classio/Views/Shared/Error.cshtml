@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
    Layout = "_Layout";
}

<div class="error-page d-flex flex-column align-items-center justify-content-center text-center py-5">

    <div class="error-icon mb-4">
        <i class="bi bi-exclamation-triangle-fill"></i>
    </div>

    <h1 class="error-title mb-2">Something went wrong</h1>
    <p class="error-subtitle mb-4">An unexpected error occurred. Please try again or return to the home page.</p>

    @if (Model?.ShowRequestId == true)
    {
        <p class="error-id mb-4">
            <span>Request ID:</span> <code>@Model.RequestId</code>
        </p>
    }

    <a href="/" class="btn-home">
        <i class="bi bi-house-fill me-2"></i>Back to Home
    </a>
</div>

<style>
    .error-page {
        min-height: 65vh;
    }

    .error-icon i {
        font-size: 5rem;
        color: #E76F51;
        opacity: 0.85;
    }

    .error-title {
        font-size: 2.2rem;
        font-weight: 700;
        color: #264653;
    }

    .error-subtitle {
        font-size: 1.05rem;
        color: #6c757d;
        max-width: 480px;
    }

    .error-id {
        font-size: 0.85rem;
        color: #adb5bd;
    }

    .error-id code {
        background: #f1f3f5;
        padding: 2px 6px;
        border-radius: 4px;
        font-size: 0.8rem;
        color: #495057;
    }

    .btn-home {
        display: inline-flex;
        align-items: center;
        background: #2A9D8F;
        color: white;
        font-weight: 600;
        font-size: 0.95rem;
        padding: 0.6rem 1.6rem;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.2s, transform 0.1s;
    }

    .btn-home:hover {
        background: #21867a;
        color: white;
        transform: translateY(-1px);
    }
</style>
